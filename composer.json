  "require-dev": {
    "larena/core": "dev-main",
    "larena/licensing": "dev-main",
    "larena/ui": "dev-main",
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^12.5",
    "symfony/yaml": "^7.3"
  },
  "scripts": {
    "test": "@php vendor/bin/phpunit --configuration=phpunit.xml.dist",
    "test:contract": "@php vendor/bin/phpunit --configuration=phpunit.xml.dist --testsuite=contract",
    "test:unit": "@php vendor/bin/phpunit --configuration=phpunit.xml.dist --testsuite=unit",
    "test:feature": "@php vendor/bin/phpunit --configuration=phpunit.xml.dist --testsuite=feature",
    "test:sqlite": "@php vendor/bin/phpunit --configuration=phpunit.xml.dist --exclude-group=mysql",
    "test:mysql": "@php vendor/bin/phpunit --configuration=phpunit.xml.dist --group=mysql",
    "test:concurrency": "@php vendor/bin/phpunit --configuration=phpunit.xml.dist --filter=Concurrency",
    "test:http": "@php vendor/bin/phpunit --configuration=phpunit.xml.dist --filter=Http",
    "test:rollback": "@php vendor/bin/phpunit --configuration=phpunit.xml.dist --filter=Migration",
    "lint": "@php scripts/lint.php",
    "analyse": "@php vendor/bin/phpstan analyse --configuration=phpstan.neon.dist --no-progress --memory-limit=1G",
    "validate:larena": "@php scripts/validate-larena-package.php",
    "evidence:check": "@php scripts/check-evidence.php",
    "scope:check": "@php tools/larena-scope-check.php",
    "quality:gate": [
      "@validate:larena",
      "@lint",
      "@analyse",
      "@test",
      "@evidence:check",
      "@scope:check"
    ]
  },
  "extra": {
    "laravel": {
      "providers": [
        "Larena\\Content\\Providers\\ContentServiceProvider"
      ]
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {},
    "platform": {
      "php": "8.3.31"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
